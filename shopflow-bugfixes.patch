 src/pages/account/AccountPage.tsx  | 20 +++++++++------
 src/pages/account/OrdersPage.tsx   |  5 ++--
 src/pages/admin/AdminInventory.tsx | 39 +++++++-----------------------
 src/pages/admin/AdminProducts.tsx  | 34 ++++++++++++--------------
 5 files changed, 43 insertions(+), 59 deletions(-)

