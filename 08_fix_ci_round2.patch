From ba522301ff6325d3a2ed6ebb1b57b8d0e5bd5be6 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Wed, 4 Mar 2026 17:00:22 +0000
Subject: [PATCH] fix: resolve second round of CI type errors

- empty.tsx, button-group.tsx: add missing React import
- badge.tsx: add explicit className to BadgeProps to fix type conflict
- ProductCard: add React import + cast Link params to fix slug type error
- tsconfig.json: enable strictNullChecks (required by TanStack Router v1)
- App.tsx: revert routeTree cast (no longer needed with strictNullChecks on)
---
 src/App.tsx                           | 3 +--
 src/components/shared/ProductCard.tsx | 4 ++--
 src/components/ui/badge.tsx           | 1 +
 src/components/ui/button-group.tsx    | 1 +
 src/components/ui/empty.tsx           | 1 +
 tsconfig.json                         | 2 +-
 6 files changed, 7 insertions(+), 5 deletions(-)

diff --git a/src/App.tsx b/src/App.tsx
index bd0af2f..6e2e68d 100644
--- a/src/App.tsx
+++ b/src/App.tsx
@@ -211,8 +211,7 @@ const routeTree = rootRoute.addChildren([
   ]),
 ])
 
-// eslint-disable-next-line @typescript-eslint/no-explicit-any
-const router = createRouter({ routeTree: routeTree as any })
+const router = createRouter({ routeTree })
 
 declare module '@tanstack/react-router' {
   interface Register {
diff --git a/src/components/shared/ProductCard.tsx b/src/components/shared/ProductCard.tsx
index e82f4fe..691d538 100644
--- a/src/components/shared/ProductCard.tsx
+++ b/src/components/shared/ProductCard.tsx
@@ -1,7 +1,7 @@
+import React from 'react'
 import { Link } from '@tanstack/react-router'
 import { ShoppingCart, Package } from 'lucide-react'
 import { Button } from '../ui/button'
-import { Badge } from '../ui/badge'
 import { formatINR } from '@/lib/format'
 import { useCart } from '@/lib/cart-context'
 import { useAuth } from '@/lib/auth-context'
@@ -31,7 +31,7 @@ export function ProductCard({ product }: ProductCardProps) {
   }
 
   return (
-    <Link to="/product/$slug" params={{ slug: product.slug }} className="group block">
+    <Link to="/product/$slug" params={{ slug: product.slug } as any} className="group block">
       <div className="product-card rounded-xl border bg-card overflow-hidden shadow-sm">
         {/* Image */}
         <div className="relative aspect-square overflow-hidden bg-muted">
diff --git a/src/components/ui/badge.tsx b/src/components/ui/badge.tsx
index 542ce05..a6d33e1 100644
