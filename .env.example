# ============================================================
# ShopFlow Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Supabase (REQUIRED) ---
# Get these from: https://app.supabase.com → Project → Settings → API

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe to expose to frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - ONLY used by Edge Functions (server-side)
# NEVER expose this to the frontend / client-side code
# Required for: checkout server-validation, admin product creation
# Set this in Supabase Edge Functions secrets (not .env.local):
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
