From 1d58f1ce8ce8729de3ba93f88001a8041bef40bc Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Tue, 3 Mar 2026 20:47:53 +0000
Subject: [PATCH] fix: stop duplicate seeding and fix broken product images

- AdminDashboard: replace broken edge function seed with direct Supabase + slug-based
  duplicate check (skips products that already exist instead of re-inserting them)
- AdminDashboard: show clear message when products were skipped vs added
- AdminSeedPage: fix all 30 Unsplash image URLs (add auto=format&fit=crop so images load)
- AdminDashboard/SeedPage: both now use same reliable image URLs
---
 src/pages/admin/AdminDashboard.tsx | 77 +++++++++++++++++++++---------
 src/pages/admin/AdminSeedPage.tsx  | 60 +++++++++++------------
 2 files changed, 85 insertions(+), 52 deletions(-)

diff --git a/src/pages/admin/AdminDashboard.tsx b/src/pages/admin/AdminDashboard.tsx
index f71a2ce..2c889f3 100644
--- a/src/pages/admin/AdminDashboard.tsx
+++ b/src/pages/admin/AdminDashboard.tsx
@@ -3,10 +3,29 @@ import { Link } from '@tanstack/react-router'
 import { Package, Tag, Warehouse, ShoppingBag, TrendingUp, AlertCircle, Loader2, Sparkles } from 'lucide-react'
 import { AdminLayout } from '../../components/admin/AdminLayout'
 import { Button } from '../../components/ui/button'
-import { formatINR } from '../../lib/format'
+import { formatINR, slugify } from '../../lib/format'
 import { supabase } from '../../lib/supabase'
 import toast from 'react-hot-toast'
 
+const DEMO_CATEGORIES = [
+  { name: 'Electronics', slug: 'electronics' },
+  { name: 'Fashion', slug: 'fashion' },
+  { name: 'Home & Kitchen', slug: 'home-kitchen' },
+]
+
+const DEMO_PRODUCTS = [
+  { title: 'Wireless Bluetooth Earbuds', price: 199900, cat: 'electronics', image: 'https://images.unsplash.com/photo-1590658268037-6bf12165a8df?w=600&auto=format&fit=crop', desc: 'Premium wireless earbuds with 30hr battery life and active noise cancellation.' },
+  { title: 'Smartwatch Pro', price: 349900, cat: 'electronics', image: 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=600&auto=format&fit=crop', desc: 'Feature-packed smartwatch with health tracking, GPS, and 7-day battery.' },
+  { title: 'USB-C Fast Charger 65W', price: 149900, cat: 'electronics', image: 'https://images.unsplash.com/photo-1591799264318-7e6ef8ddb7ea?w=600&auto=format&fit=crop', desc: 'Universal 65W fast charger compatible with laptops, phones, and tablets.' },
+  { title: "Men's Classic Kurta", price: 89900, cat: 'fashion', image: 'https://images.unsplash.com/photo-1614676471928-2ed0ad1061a4?w=600&auto=format&fit=crop', desc: 'Premium cotton kurta with elegant embroidery. Perfect for festivals.' },
+  { title: "Women's Silk Saree", price: 249900, cat: 'fashion', image: 'https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=600&auto=format&fit=crop', desc: 'Pure silk saree with traditional zari work. Available in multiple colors.' },
+  { title: 'Running Sneakers', price: 179900, cat: 'fashion', image: 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600&auto=format&fit=crop', desc: 'Lightweight running shoes with advanced cushioning and breathable mesh.' },
+  { title: 'Non-Stick Cookware Set', price: 259900, cat: 'home-kitchen', image: 'https://images.unsplash.com/photo-1584990347449-a2a4fa6b7c7e?w=600&auto=format&fit=crop', desc: '5-piece premium non-stick cookware set. Dishwasher safe, PFOA free.' },
+  { title: 'Electric Kettle 1.5L', price: 129900, cat: 'home-kitchen', image: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&auto=format&fit=crop', desc: 'BPA-free electric kettle with auto shut-off and keep-warm function.' },
+  { title: 'LED Desk Lamp', price: 99900, cat: 'electronics', image: 'https://images.unsplash.com/photo-1507473885765-e6ed057f782c?w=600&auto=format&fit=crop', desc: 'Adjustable LED desk lamp with 5 color temperatures and USB charging port.' },
+  { title: 'Bamboo Cutting Board', price: 59900, cat: 'home-kitchen', image: 'https://images.unsplash.com/photo-1584568694244-14fbdf83bd30?w=600&auto=format&fit=crop', desc: 'Eco-friendly bamboo cutting board with juice groove and non-slip feet.' },
+]
+
 interface Stats {
   products: number
   categories: number
@@ -43,31 +62,45 @@ export function AdminDashboard() {
     if (!confirm('This will insert 3 categories and 10 demo products. Existing data will not be deleted. Continue?')) return
     setSeeding(true)
 
-    const { data: { session } } = await supabase.auth.getSession()
-    const token = session?.access_token
-
     try {
-      // Try edge function first, fall back to direct supabase
-      const supabaseUrl = import.meta.env.VITE_SUPABASE_URL
-      const res = await fetch(`${supabaseUrl}/functions/v1/api-admin/seed`, {
-        method: 'POST',
-        headers: {
-          'Content-Type': 'application/json',
-          'Authorization': `Bearer ${token}`,
-        },
-      })
+      // 1. Ensure categories exist (upsert by slug)
+      const catMap: Record<string, string> = {}
+      for (const cat of DEMO_CATEGORIES) {
+        const { data: existing } = await supabase.from('categories').select('id').eq('slug', cat.slug).maybeSingle()
+        if (existing) { catMap[cat.slug] = existing.id; continue }
+        const { data } = await supabase.from('categories').insert(cat).select('id').single()
+        if (data) catMap[cat.slug] = data.id
+      }
 
-      if (res.ok) {
-        const result = await res.json()
-        toast.success(`Seeded: ${result.data?.categories} categories, ${result.data?.products} products!`)
-        // Refresh stats
-        window.location.reload()
-      } else {
-        const err = await res.json()
-        toast.error(err.error || 'Seed failed')
+      // 2. Insert products, skipping any that already exist (by slug)
+      let added = 0
+      let skipped = 0
+      for (const p of DEMO_PRODUCTS) {
+        const slug = slugify(p.title)
+        const { data: exists } = await supabase.from('products').select('id').eq('slug', slug).maybeSingle()
+        if (exists) { skipped++; continue }
+        const { data, error } = await supabase.from('products').insert({
+          title: p.title, slug,
+          description: p.desc,
+          price_paise: p.price,
+          status: 'ACTIVE',
+          visibility: 'PUBLIC',
+          category_id: catMap[p.cat] || null,
+          image_url: p.image,
+        }).select('id').single()
+        if (!error && data) {
+          await supabase.from('inventory').insert({ product_id: data.id, stock: Math.floor(Math.random() * 45) + 5 })
+          added++
+        }
       }
+
+      const msg = skipped > 0
+        ? `Added ${added} products (${skipped} already existed, skipped)`
+        : `Seeded ${added} products and ${Object.keys(catMap).length} categories!`
+      toast.success(msg)
+      window.location.reload()
     } catch (err: any) {
-      toast.error(err.message || 'Seed request failed')
+      toast.error(err.message || 'Seed failed')
     }
     setSeeding(false)
   }
